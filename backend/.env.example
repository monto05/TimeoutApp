# Copia este archivo como .env en la carpeta backend/ para desarrollo local
# En Railway, configura estas variables en el panel "Variables" del proyecto

# Puerto (Railway lo asigna automáticamente)
PORT=3001

# Para desarrollo local usa la URL de abajo.
# Para producción (Railway) usa tu URL de MongoDB Atlas:
# mongodb+srv://USUARIO:PASSWORD@cluster0.xxxxx.mongodb.net/timeout_app
MONGODB_URL="mongodb://127.0.0.1:27017"

MONGODB_DB_NAME="timeout_app"

# Cambiar a "production" en Railway
NODE_ENV=development
