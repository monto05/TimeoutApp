{
  "name": "timeout-coaches",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "npm run dev -w frontend",
    "api:dev": "npm run dev -w backend",
    "dev:all": "concurrently -n frontend,backend -c cyan,magenta \"npm run dev\" \"npm run api:dev\"",
    "build": "npm run build -w frontend",
    "start": "npm run start -w backend",
    "preview": "npm run preview -w frontend",
    "db:generate": "npm run db:generate -w backend",
    "db:migrate": "npm run db:migrate -w backend",
    "db:studio": "npm run db:studio -w backend"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
